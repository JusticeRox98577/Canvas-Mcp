{
  "name": "canvas-mcp",
  "version": "1.0.0",
  "description": "Canvas LMS MCP server — automatically logs in via browser, no API token or manual cookie copying required",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "canvas-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "install-browser": "npx playwright install chromium --with-deps"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
